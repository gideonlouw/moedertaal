{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Moedertaal",
  "scopeName": "source.moedertaal",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#values" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [{ "name": "comment.line.number-sign.moedertaal", "match": "#.*$" }]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.moedertaal",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.moedertaal", "match": "\\\\[nrt\\\\\"']" }]
        },
        {
          "name": "string.quoted.single.moedertaal",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.moedertaal", "match": "\\\\[nrt\\\\\"']" }]
        }
      ]
    },
    "numbers": {
      "patterns": [{ "name": "constant.numeric.moedertaal", "match": "\\b\\d+(?:\\.\\d+)?\\b" }]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.moedertaal",
          "match": "\\b(?:sГҒ|skryf|stel|as|anders|einde|herhaal|vir|in|funksie|gee|say|print|set|let|if|else|end|repeat|for|function|return|иҮө|иң“е‡ғ|и®ңзҢ®|и®ң|е¦‚жһњ|еђ¦е€™|з»“жқџ|й‡Қе¤Қ|еҮ№дғҺ|ењЁ|е‡Ңж•°|иү”е›һ)\\b"
        },
        {
          "name": "keyword.operator.word.moedertaal",
          "match": "\\b(?:en|of|nie|and|or|not|дё”|ж€–|йқһ)\\b"
        }
      ]
    },
    "values": {
      "patterns": [
        {
          "name": "constant.language.moedertaal",
          "match": "\\b(?:waar|onwaar|niks|true|false|nothing|зњџ|еЃ‡|з©ғ)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(funksie|function|е‡Ңж•°)\\s+([\\p{L}_][\\p{L}\\p{N}_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "keyword.control.moedertaal" },
            "2": { "name": "entity.name.function.moedertaal" }
          }
        }
      ]
    }
  }
}
